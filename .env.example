# Agience — environment overrides
# Copy to .env and uncomment only what you need. Never commit .env to git.
#
# Most platform settings (OAuth, AI keys, URIs, access control, content
# storage) are configured through the browser setup wizard and stored in the
# database. This file is for Docker Compose interpolation and backend
# network/host overrides that must be known before the DB is available.


# -- Data and images -----------------------------------------------------------
# DATA_PATH=./.data
# REGISTRY=ghcr.io/agience
# VERSION=latest


# -- Service hosts (override to point at external or split infra) --------------
# ARANGO_HOST=graph
# OPENSEARCH_HOST=search
# AGIENCE_SERVER_HOST_URI=http://servers:8082
# AGIENCE_API_URI=http://backend:8081
# SRS_HTTP_API=http://stream:1985
# STREAM_BASE_URL=http://stream:1985/live
# STREAM_INGEST_URL=rtmp://localhost:1936/live
# BACKEND_URI=http://servers:8082/astra


# -- ArangoDB ------------------------------------------------------------------
# Password is auto-generated by the init container on first boot.
# Set before first boot only when importing an existing dataset.
# ARANGO_ROOT_PASSWORD=


# -- MinIO (content storage) ---------------------------------------------------
# Credentials are auto-generated by the init container on first boot.
# Set before first boot only when importing an existing dataset.
# MINIO_ROOT_USER=agience
# MINIO_ROOT_PASSWORD=


# -- OpenSearch ----------------------------------------------------------------
# OPENSEARCH_CLUSTER_NAME=agience-search
# OPENSEARCH_INITIAL_HEAP_SIZE=256m
# OPENSEARCH_MAXIMUM_HEAP_SIZE=256m


# -- AI / LLM ------------------------------------------------------------------
# Powers embeddings (semantic search) and LLM completions.
# If set here, the setup wizard will detect it and skip the AI key prompt.
# The value is used by the backend and passed to MCP server containers.
# Can also be configured later via the setup wizard or settings page.
# OPENAI_API_KEY=


# -- Google OAuth --------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/auth/callback


# -- Frontend build (Vite) -----------------------------------------------------
# VITE_BACKEND_URI=http://localhost:8081
# VITE_CLIENT_ID=
# VITE_TITLE=Agience
# VITE_FAVICON=/favicon.ico
