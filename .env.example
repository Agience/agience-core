# Agience — environment overrides
# Copy to .env and uncomment only what you need. Never commit .env to git.
#
# Most platform settings (OAuth, AI keys, URIs, access control, content
# storage) are configured through the browser setup wizard and stored in the
# database. This file is for Docker Compose interpolation and pre-DB overrides
# that must be known before the platform is available.


# -- Data and images -----------------------------------------------------------
# DATA_PATH=./.data
# REGISTRY=agience               # Docker Hub namespace
# VERSION=stable                 # `stable` (default) or `edge`


# -- Service URIs (four-container architecture) --------------------------------
# Override only when running services on non-default hosts/ports or behind
# external proxies. Inside compose, defaults point at container names.
# ORIGIN_URI=http://origin:8080            # Identity / OIDC / grants
# MANTLE_URI=http://mantle:8081              # Artifact kernel + encrypted search
# CHORUS_URI=http://chorus:8082            # MCP universal gateway
# ARANGO_HOST=graph                        # Arango container name


# -- Streaming (optional, for live media via SRS) ------------------------------
# SRS_HTTP_API=http://stream:1985
# STREAM_BASE_URL=http://stream:1985/live
# STREAM_INGEST_URL=rtmp://localhost:1936/live


# -- ArangoDB (Mantle) ----------------------------------------------------------
# Password is auto-generated by the init container on first boot.
# Set before first boot only when importing an existing dataset.
# ARANGO_ROOT_PASSWORD=


# -- MinIO (content + encrypted MANTLE+SSE search blobs) ------------------------
# Credentials are auto-generated by the init container on first boot.
# Set before first boot only when importing an existing dataset.
# MINIO_ROOT_USER=agience
# MINIO_ROOT_PASSWORD=

# When MCP servers run in a different network context than Mantle, presigned
# S3 URLs may use a hostname the servers can't reach. Set this to override
# the endpoint used for server-facing presigned URLs.
# CONTENT_EDGE_ENDPOINT_URL=http://host.docker.internal:9000


# -- AI / LLM ------------------------------------------------------------------
# Powers chat, synthesis, and AI features.
# LLM_PROVIDER: openai | anthropic | openrouter | relay
# LLM_API_KEY: API key for the configured provider.
# If set here, the setup wizard will detect it and skip the AI key prompt.
# Can also be configured via the browser setup wizard or settings page.
# LLM_PROVIDER=anthropic
# LLM_API_KEY=
# AI_DEFAULT_MODEL=claude-sonnet-4-6
# AI_QUICK_MODEL=claude-haiku-4-5-20251001

# Embeddings — feeds the MANTLE encrypted vector search arm. Embeddings is an
# EXTERNAL service (managed separately, not a compose container): point
# EMBEDDINGS_URI at a reachable bge-m3 (1024-dim) `/embed` endpoint — e.g. a
# managed GPU host (see package/docker/embeddings.gpu.Dockerfile, src/embeddings/).
# When unset, search degrades to MANTLE-SSE lexical-only.
# EMBEDDINGS_PROVIDER=agience
# EMBEDDINGS_URI=https://your-embeddings-host.example/
# EMBEDDINGS_DIM=1024
# Set only if the embeddings server enforces a bearer token:
# EMBEDDINGS_API_KEY=


# -- Iris persona (routing & communication) ------------------------------------
# Fallback recipient for inbound artifact operator notifications.
# If notify_to is omitted from the notify_inbound tool call, this address is used.
# IRIS_NOTIFY_EMAIL=


# -- Google OAuth --------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
# Refresh token for the sending mailbox — required for EMAIL_PROVIDER=gmail.
# Obtain via a one-time OAuth consent with the gmail.send scope.
# GOOGLE_OAUTH_REFRESH_TOKEN=


# -- Email (platform transactional: sign-in OTP, password reset, invites) ------
# Provider 'gmail' sends via the Gmail API, reusing the Google OAuth app above —
# it validates against GOOGLE_OAUTH_* (client id + secret + refresh token).
# Other providers (smtp | ses | sendgrid | resend) are configured via the wizard.
# EMAIL_PROVIDER=gmail
# PLATFORM_EMAIL_ADDRESS=you@yourdomain.com


# -- Facet (Vite) build-time URIs ----------------------------------------------
# VITE_ORIGIN_URI=http://localhost:8080
# VITE_MANTLE_URI=http://localhost:8081
# VITE_CLIENT_ID=
# VITE_TITLE=Agience
# VITE_FAVICON=/favicon.ico
