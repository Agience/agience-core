#!/usr/bin/env bash
# pre-push hook: run docs integrity (including broken-link check) before every push.
# Install: run `.scripts/install-hooks.ps1` (Windows) or `git config core.hooksPath .githooks`

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "==> pre-push: docs integrity check"
python "$REPO_ROOT/.scripts/check_docs_integrity.py"
echo "==> pre-push: OK"
