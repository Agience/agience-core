{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "knn": true,
      "knn.algo_param.ef_search": 512
    },
    "analysis": {
      "filter": {
        "english_stop": {
          "type": "stop",
          "stopwords": "_english_"
        },
        "english_stemmer": {
          "type": "stemmer",
          "language": "english"
        },
        "english_possessive_stemmer": {
          "type": "stemmer",
          "language": "possessive_english"
        }
      },
      "analyzer": {
        "english_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "english_possessive_stemmer",
            "english_stop",
            "english_stemmer"
          ]
        }
      },
      "normalizer": {
        "lowercase_normalizer": {
          "type": "custom",
          "filter": ["lowercase"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "root_id": {
        "type": "keyword"
      },
      "version_id": {
        "type": "keyword"
      },
      "owner_id": {
        "type": "keyword",
        "index": true
      },
      "collection_id": {
        "type": "keyword",
        "index": true
      },
      "share_keys": {
        "type": "keyword",
        "index": true
      },
      "state": {
        "type": "keyword",
        "index": true
      },
      "is_head": {
        "type": "boolean"
      },
      "chunk_index": {
        "type": "integer"
      },
      "title": {
        "type": "text",
        "analyzer": "english_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },
      "description": {
        "type": "text",
        "analyzer": "english_analyzer"
      },
      "content": {
        "type": "text",
        "analyzer": "english_analyzer"
      },
      "chunk_text": {
        "type": "text",
        "analyzer": "english_analyzer"
      },
      "tags_canonical": {
        "type": "keyword",
        "normalizer": "lowercase_normalizer"
      },
      "metadata": {
        "type": "object",
        "properties": {
          "content_type": {
            "type": "keyword"
          },
          "updated_at": {
            "type": "date"
          }
        },
        "dynamic": true
      },
      "content_vector": {
        "type": "knn_vector",
        "dimension": 1536,
        "method": {
          "name": "hnsw",
          "space_type": "cosinesimil",
          "engine": "faiss",
          "parameters": {
            "ef_construction": 512,
            "m": 16
          }
        }
      },
      "indexed_at": {
        "type": "date"
      }
    }
  }
}
