{
  "content_type": "application/vnd.agience.search+json",
  "version": 1,
  "inherits": ["application/json"],
  "description": "A search flavor — an invokable artifact that runs a search strategy over the caller's authorized candidate set. The standard flavor runs the open RRF search in-core; premium flavors (e.g. Beacon) dispatch to an external server and may require an entitlement.",
  "ui": {
    "label": "Search",
    "icon": "search",
    "color": "#0ea5e9",
    "viewer": "search"
  },
  "operations": {
    "invoke": {
      "enabled": true,
      "requires_grant": "invoke",
      "dispatch": {
        "kind": "native",
        "target": "services.search_flavors.run_search"
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "query_text": { "type": "string" },
          "embedding": { "type": "array", "items": { "type": "number" } },
          "scope": { "type": "array", "items": { "type": "string" } },
          "size": { "type": "integer" },
          "from": { "type": "integer" }
        }
      },
      "emits": [
        { "event": "artifact.invoke.started", "phase": "before" },
        { "event": "artifact.invoke.completed", "phase": "after" },
        { "event": "artifact.invoke.failed", "phase": "error" }
      ]
    }
  }
}
