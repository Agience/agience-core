{
  "content_type": "application/vnd.agience.relay-session+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "Desktop Host Relay session metadata — one artifact per connected desktop host. Session transport (WebSocket) is managed natively by the relay; this artifact carries only discoverable state (host id, user, last-seen, capabilities) so clients can list / observe their active hosts through the generic artifact + events APIs.",
  "operations": {
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "native", "target": "desktop_host_relay_service.disconnect_session_by_artifact_id" },
      "emits": [
        { "event": "relay.session.disconnected", "phase": "after" }
      ]
    }
  },
  "ui": {
    "label": "Relay Session",
    "icon": "monitor-smartphone",
    "color": "#06b6d4",
    "badge_class": "bg-cyan-100 text-cyan-800",
    "modes": [ "floating" ],
    "states": [ "view" ],
    "default_mode": "floating",
    "default_state": "view",
    "is_container": false,
    "creatable": false,
    "viewer": null
  }
}
