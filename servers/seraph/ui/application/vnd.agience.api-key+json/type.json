{
  "content_type": "application/vnd.agience.api-key+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "Agience scoped API key. Key material is shown once at create-time and never returned again; subsequent reads expose metadata (scopes, resource filters, last-used, etc.) only.",
  "operations": {
    "create": {
      "enabled": true,
      "requires_grant": "create",
      "dispatch": { "kind": "native", "target": "api_key_service.create_api_key" },
      "audit": true,
      "emits": [
        { "event": "api_key.created", "phase": "after" }
      ]
    },
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "api_key.updated", "phase": "after" }
      ]
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "native", "target": "api_key_service.delete_api_key" },
      "emits": [
        { "event": "api_key.revoked", "phase": "after" }
      ]
    }
  },
  "ui": {
    "label": "API Key",
    "icon": "key",
    "color": "#f59e0b",
    "badge_class": "bg-amber-100 text-amber-800",
    "modes": [ "floating" ],
    "states": [ "view" ],
    "default_mode": "floating",
    "default_state": "view",
    "is_container": false,
    "creatable": true,
    "viewer": null
  }
}
