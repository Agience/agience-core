{
  "content_type": "application/vnd.agience.market-snapshot+json",
  "version": 1,
  "inherits": ["application/json"],
  "description": "A point-in-time market measurement — implied volatility, a vol surface, perp funding, or a quote — for one instrument at one moment. Small structured JSON payload; metadata-only indexing (numeric, not embedded).",
  "context_schema": {
    "symbol": { "type": "string", "description": "Instrument symbol.", "index": ["lexical"], "mutable": false },
    "kind":   { "type": "string", "description": "Snapshot kind (iv, surface, funding, oi, quote).", "index": ["lexical"], "mutable": false },
    "as_of":  { "type": "string", "description": "ISO-8601 timestamp of the measurement.", "index": ["temporal"], "mutable": false },
    "venue":  { "type": "string", "description": "Venue / vendor (deribit, laevitas, binance).", "index": ["lexical"], "mutable": false },
    "tenor":  { "type": "string", "description": "Tenor / expiry the measurement applies to, if any.", "mutable": false }
  },
  "operations": {
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [ { "event": "artifact.updated", "phase": "after" } ]
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [ { "event": "artifact.deleted", "phase": "after" } ]
    }
  },
  "ui": {
    "label": "Market Snapshot",
    "icon": "activity",
    "color": "#10b981",
    "badge_class": "bg-emerald-100 text-emerald-800",
    "tile_class": "",
    "modes": ["floating", "preview"],
    "states": ["view"],
    "default_mode": "preview",
    "default_state": "view",
    "is_container": false,
    "creatable": false
  }
}
