{
  "content_type": "application/vnd.agience.authorizer+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "Agience Authorizer",
  "operations": {
    "invoke": {
      "enabled": true,
      "requires_grant": "invoke",
      "dispatch": {
        "kind": "mcp_tool",
        "server_ref": "seraph",
        "tool_ref": "provide_access_token",
        "arguments": {
          "authorizer_config": "$.content",
          "authorizer_artifact_id": "$.root_id"
        }
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "workspace_id": { "type": "string" }
        }
      },
      "emits": [
        { "event": "authorizer.token.provided", "phase": "after" },
        { "event": "authorizer.token.failed", "phase": "error" }
      ]
    }
  },
  "ui": {
    "label": "Authorizer",
    "icon": "shield",
    "color": "#dc2626",
    "badge_class": "bg-red-100 text-red-800",
    "tile_class": "",
    "modes": [
      "floating",
      "preview"
    ],
    "states": [
      "view",
      "edit"
    ],
    "default_mode": "floating",
    "default_state": "view",
    "is_container": false,
    "creatable": true,
    "viewer": "authorizer"
  }
}
