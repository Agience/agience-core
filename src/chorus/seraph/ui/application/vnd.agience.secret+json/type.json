{
  "content_type": "application/vnd.agience.secret+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "Agience Secret (metadata only; secret material stored out-of-band)",
  "operations": {
    "create": {
      "enabled": true,
      "requires_grant": "create",
      "dispatch": { "kind": "artifact_crud" },
      "audit": true,
      "emits": [ { "event": "secret.created", "phase": "after" } ]
    },
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "audit": true,
      "emits": [ { "event": "secret.updated", "phase": "after" } ]
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [ { "event": "secret.deleted", "phase": "after" } ]
    },
    "fetch": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "native", "target": "secrets_service.fetch_secret_material" },
      "audit": true,
      "emits": [
        { "event": "secret.fetched", "phase": "after" }
      ]
    }
  },
  "ui": {
    "label": "Secret",
    "icon": "lock",
    "color": "#dc2626",
    "badge_class": "bg-red-100 text-red-800",
    "tile_class": "",
    "modes": [
      "floating"
    ],
    "states": [
      "view"
    ],
    "default_mode": "floating",
    "default_state": "view",
    "is_container": false,
    "creatable": false,
    "viewer": null
  }
}
