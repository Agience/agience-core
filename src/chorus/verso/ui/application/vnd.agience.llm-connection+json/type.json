{
  "content_type": "application/vnd.agience.llm-connection+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "LLM Connection \u2014 configures access to a language model provider with credential resolution and rate limiting.",
  "context_schema": {
    "provider": {
      "type": "string",
      "enum": [
        "openai",
        "anthropic",
        "azure",
        "google",
        "mistral",
        "local"
      ],
      "description": "LLM provider identifier"
    },
    "model": {
      "type": "string",
      "description": "Model identifier (e.g. gpt-5-nano, claude-opus-4, claude-sonnet-4)"
    },
    "endpoint": {
      "type": "string",
      "description": "Custom API endpoint URL (optional, for Azure, local, or resold connections)"
    },
    "credentials_ref": {
      "type": "object",
      "description": "Pointer to credentials \u2014 never contains actual keys. Seraph resolves this at invocation time.",
      "properties": {
        "secret_id": {
          "type": "string",
          "description": "Exact secret UUID (if user-supplied)"
        },
        "secret_type": {
          "type": "string",
          "default": "llm_key",
          "description": "Secret type for lookup in secrets service"
        },
        "provider": {
          "type": "string",
          "description": "Provider discriminator for secret lookup"
        },
        "resolution": {
          "type": "string",
          "enum": [
            "user_secret",
            "workspace_secret",
            "platform_default"
          ],
          "description": "How to resolve the key at invocation time"
        }
      }
    },
    "rate_limits": {
      "type": "object",
      "description": "Rate limits applied per-user for this connection",
      "properties": {
        "requests_per_minute": {
          "type": "integer",
          "description": "Max requests per minute"
        },
        "tokens_per_minute": {
          "type": "integer",
          "description": "Max tokens per minute"
        },
        "tokens_per_day": {
          "type": "integer",
          "description": "Max tokens per day"
        }
      }
    },
    "tier": {
      "type": "string",
      "enum": [
        "free",
        "pro",
        "power",
        "custom"
      ],
      "description": "Subscription tier this connection belongs to"
    },
    "capabilities": {
      "type": "object",
      "description": "Model capabilities for UX and routing decisions",
      "properties": {
        "chat": {
          "type": "boolean"
        },
        "reasoning": {
          "type": "boolean"
        },
        "vision": {
          "type": "boolean"
        },
        "function_calling": {
          "type": "boolean"
        },
        "max_context_tokens": {
          "type": "integer"
        }
      }
    },
    "is_platform_default": {
      "type": "boolean",
      "description": "True for platform-seeded default connections"
    },
    "title": {
      "type": "string",
      "description": "Human-readable name for this connection"
    },
    "description": {
      "type": "string",
      "description": "Brief explanation of this connection"
    }
  },
  "ui": {
    "label": "LLM Connection",
    "icon": "brain",
    "color": "#7c3aed",
    "badge_class": "bg-violet-100 text-violet-800",
    "tile_class": "ring-1 ring-violet-200/70",
    "modes": [
      "floating",
      "preview"
    ],
    "states": [
      "view"
    ],
    "default_mode": "floating",
    "default_state": "view",
    "is_container": false,
    "creatable": true,
    "viewer": "llm-connection"
  }
}
