{
  "content_type": "application/vnd.agience.tool+json",
  "version": 1,
  "inherits": ["application/json"],
  "description": "MCP Tool artifact. Invoking routes to context.server_id:context.tool_name so any server — first-party or third-party — can own this artifact.",
  "context_schema": {
    "server_id":    { "type": "string", "description": "UUID of the MCP server artifact that owns this tool.", "mutable": false },
    "tool_name":    { "type": "string", "description": "MCP tool name as declared by the server.", "mutable": false },
    "description":  { "type": "string", "description": "Human-readable description.", "mutable": true },
    "input_schema": { "type": "object", "description": "JSON Schema for tool input parameters.", "mutable": false },
    "notes":        { "type": "string", "description": "User notes.", "mutable": true }
  },
  "operations": {
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "invoke": {
      "enabled": true,
      "requires_grant": "invoke",
      "dispatch": {
        "kind": "mcp_tool",
        "server_ref": "$.context.server_id",
        "tool_ref":   "$.context.tool_name"
      },
      "emits": [
        { "event": "tool.invoked", "phase": "after" }
      ]
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.updated", "phase": "after" }
      ]
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.deleted", "phase": "after" }
      ]
    }
  },
  "ui": {
    "label": "Tool",
    "icon": "zap",
    "color": "#a855f7",
    "badge_class": "bg-violet-100 text-violet-800",
    "tile_class": "",
    "modes": ["floating", "preview"],
    "states": ["view"],
    "default_mode": "preview",
    "default_state": "view",
    "is_container": false,
    "creatable": false
  }
}
