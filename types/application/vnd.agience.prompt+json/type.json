{
  "content_type": "application/vnd.agience.prompt+json",
  "version": 1,
  "inherits": ["application/json"],
  "description": "MCP Prompt — a server-provided prompt template materialized as an artifact.",
  "context_schema": {
    "prompt_name": { "type": "string", "description": "MCP prompt name", "mutable": false },
    "description": { "type": "string", "description": "Human-readable description", "mutable": true },
    "arguments": {
      "type": "array",
      "description": "Prompt argument definitions",
      "items": {
        "type": "object",
        "properties": {
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "required":    { "type": "boolean" }
        }
      },
      "mutable": false
    },
    "notes": { "type": "string", "description": "User notes", "mutable": true }
  },
  "operations": {
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.updated", "phase": "after" }
      ]
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.deleted", "phase": "after" }
      ]
    }
  },
  "ui": {
    "label": "Prompt",
    "icon": "message-square",
    "color": "#8b5cf6",
    "badge_class": "bg-violet-100 text-violet-800",
    "tile_class": "",
    "modes": ["floating", "preview"],
    "states": ["view"],
    "default_mode": "preview",
    "default_state": "view",
    "is_container": false,
    "creatable": false
  }
}
