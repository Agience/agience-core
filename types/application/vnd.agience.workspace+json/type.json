{
  "content_type": "application/vnd.agience.workspace+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "Agience Workspace (container)",
  "context_schema": {
    "bindings": {
      "type": "object",
      "description": "Named role bindings linking this workspace to other artifacts.",
      "properties": {
        "memory": {
          "type": "object",
          "description": "Collection used as persistent memory for the workspace.",
          "properties": { "artifact_id": { "type": "string" } },
          "expected_content_type": "application/vnd.agience.collection+json"
        },
        "tools": {
          "type": "object",
          "description": "Collection of mcp-server+json artifacts providing tool surfaces.",
          "properties": { "artifact_id": { "type": "string" } },
          "expected_content_type": "application/vnd.agience.collection+json"
        },
        "resources": {
          "type": "object",
          "description": "Collection of artifacts available as static context for transforms.",
          "properties": { "artifact_id": { "type": "string" } },
          "expected_content_type": "application/vnd.agience.collection+json"
        },
        "ask_prompt": {
          "type": "object",
          "description": "Single prompt or chat artifact used by the ask tool.",
          "properties": { "artifact_id": { "type": "string" } }
        },
        "engagement_channels": {
          "type": "object",
          "description": "Collection of channel adapters for human engagement.",
          "properties": { "artifact_id": { "type": "string" } },
          "expected_content_type": "application/vnd.agience.collection+json"
        },
        "target_collections": {
          "type": "object",
          "description": "Collections that new artifacts in this workspace are linked to at creation time.",
          "properties": { "artifact_ids": { "type": "array", "items": { "type": "string" } } },
          "cardinality": "multi"
        }
      }
    }
  },
  "operations": {
    "create": {
      "enabled": true,
      "requires_grant": "create",
      "dispatch": { "kind": "native", "target": "workspace_service.dispatch_create_workspace" },
      "emits": [
        { "event": "artifact.created", "phase": "after" }
      ],
      "observe": { "enabled": true, "transports": ["sse", "websocket"] }
    },
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.updated", "phase": "after" }
      ],
      "observe": { "enabled": true, "transports": ["sse", "websocket"] }
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.deleted", "phase": "after" }
      ],
      "observe": { "enabled": true, "transports": ["sse", "websocket"] }
    },
    "commit": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "native", "target": "workspace_service.dispatch_commit" },
      "emits": [
        { "event": "workspace.commit.started", "phase": "before" },
        { "event": "workspace.commit.completed", "phase": "after" },
        { "event": "workspace.commit.failed", "phase": "error" }
      ]
    },
    "commit_preview": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "native", "target": "workspace_service.dispatch_commit_preview" }
    },
    "revert": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "native", "target": "workspace_service.dispatch_revert" },
      "emits": [
        { "event": "artifact.reverted", "phase": "after" }
      ]
    }
  },
  "ui": {
    "id": "workspace",
    "label": "Workspace",
    "icon": "file-text",
    "color": "#0ea5e9",
    "badge_class": "bg-sky-100 text-sky-800",
    "tile_class": "",
    "modes": [
      "tree",
      "grid",
      "list",
      "floating"
    ],
    "states": [
      "view",
      "edit",
      "expanded",
      "collapsed"
    ],
    "default_mode": "grid",
    "default_state": "view",
    "is_container": true,
    "creatable": true,
    "viewer": "workspace",
    "default_depth": 2,
    "max_depth": 5
  }
}
