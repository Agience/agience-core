{
  "content_type": "application/vnd.agience.workspace+json",
  "version": 1,
  "inherits": [
    "application/json"
  ],
  "description": "Agience Workspace (container)",
  "operations": {
    "create": {
      "enabled": true,
      "requires_grant": "create",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.created", "phase": "after" }
      ],
      "observe": { "enabled": true, "transports": ["sse", "websocket"] }
    },
    "read": {
      "enabled": true,
      "requires_grant": "read",
      "dispatch": { "kind": "artifact_crud" }
    },
    "update": {
      "enabled": true,
      "requires_grant": "update",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.updated", "phase": "after" }
      ],
      "observe": { "enabled": true, "transports": ["sse", "websocket"] }
    },
    "delete": {
      "enabled": true,
      "requires_grant": "delete",
      "dispatch": { "kind": "artifact_crud" },
      "emits": [
        { "event": "artifact.deleted", "phase": "after" }
      ],
      "observe": { "enabled": true, "transports": ["sse", "websocket"] }
    }
  },
  "ui": {
    "id": "workspace",
    "label": "Workspace",
    "icon": "file-text",
    "color": "#0ea5e9",
    "badge_class": "bg-sky-100 text-sky-800",
    "tile_class": "",
    "modes": [
      "tree",
      "grid",
      "list",
      "floating"
    ],
    "states": [
      "view",
      "edit",
      "expanded",
      "collapsed"
    ],
    "default_mode": "grid",
    "default_state": "view",
    "is_container": true,
    "creatable": true,
    "viewer": "workspace",
    "default_depth": 2,
    "max_depth": 5
  }
}
